# ============================================================================
# Wordetica (merged Next.js app) — environment template
# Copy to `.env` and replace every secret BEFORE running in production.
# Both the API (Next.js API routes wrapping the original Express backend) and
# the frontend read from this single file.
# ============================================================================

# --- Core (server / API) ---------------------------------------------------
SECRET_KEY=change-me-to-a-long-random-string
PORT=8000
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:3000
# PUBLIC_BASE_URL=https://wordetica.eu

# --- Frontend (browser) ----------------------------------------------------
# API is same-origin under /api by default — only override if the API is hosted
# elsewhere. Must be exposed with the NEXT_PUBLIC_ prefix to reach the browser.
# NEXT_PUBLIC_API_BASE_URL=/api
# NEXT_PUBLIC_BACKEND_URL=

# --- Firebase Storage (article cover images) -------------------------------
FIREBASE_STORAGE_BUCKET=wordetica.firebasestorage.app

# --- Firebase Admin SDK (required for API / Firestore) ---------------------
# Option A: path to service account JSON (git-ignored)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# Option B: inline (private key must use \n for line breaks)
FIREBASE_PROJECT_ID=wordetica
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@wordetica.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Trust proxy only when running behind a reverse proxy (production)
# TRUST_PROXY=1

# --- API pagination --------------------------------------------------------
DRF_PAGE_SIZE=10

# --- JWT -------------------------------------------------------------------
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# --- Authentication / account lockout --------------------------------------
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_UNLOCK_KEY=recunostinta

# --- Uploads ---------------------------------------------------------------
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# --- AI microservice -------------------------------------------------------
AI_SERVICE_URL=http://127.0.0.1:8200
AI_SERVICE_TIMEOUT=300

# --- SMTP (contact form) ---------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=office@wordetica.eu
SMTP_PASS=
